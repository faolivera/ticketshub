# Database
DATABASE_URL=postgresql://ticketshub:ticketshub@localhost:5433/ticketshub

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# S3 storage (required for file storage: identity-docs, payment-confirmations, avatars, event-banners)
# For local dev with LocalStack: use S3_ENDPOINT and create buckets on first use.
# For production: omit S3_ENDPOINT and create buckets via IaC or AWS console.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT=http://localhost:4567
S3_PRIVATE_BUCKET=ticketshub-private-dev
S3_PUBLIC_BUCKET=ticketshub-public-dev
