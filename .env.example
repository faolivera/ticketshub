# Local secrets for run-local.sh (and optionally backend when run from backend/).
# Copy to .env at repo root and fill in. .env is not committed.
#
# AWS (for S3 and SES when not using LocalStack/mock)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
#
# Twilio Verify (SMS OTP)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
#
# JWT (override default only if needed)
# JWT_SECRET=local-dev-secret
#
# SES sender (if using real SES)
# SES_FROM_EMAIL=
