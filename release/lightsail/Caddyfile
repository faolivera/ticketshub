# Caddy: TLS for ticketshub.shop, ticketshub.com.ar, ticketshub.ar
# Automatic HTTPS via Let's Encrypt. DNS A records must point to this host.
# Persist certs in /data (mount a volume at /data in Docker).
# ticketshub.ar redirects to ticketshub.com.ar (canonical domain).
{
	admin off
	storage file_system {
		root /data/caddy
	}
}

ticketshub.ar, www.ticketshub.ar, www.ticketshub.com.ar, www.ticketshub.shop {
	redir https://ticketshub.com.ar{uri} permanent
}

ticketshub.shop, ticketshub.com.ar {
	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /socket.io/* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /health {
		reverse_proxy 127.0.0.1:3000
	}
	handle /assets/* {
		root * /app/frontend/dist
		encode gzip
		file_server
	}
	handle {
		reverse_proxy 127.0.0.1:3000
	}
}
