# Caddy: serve frontend and reverse-proxy to backend
# Listen on PORT (set by Render); default 8080 for local runs
# API/socket/health must be handled first, then static SPA (otherwise /api/* gets index.html)
:{$PORT:8080} {
	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /socket.io/* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /health {
		reverse_proxy 127.0.0.1:3000
	}
	handle {
		root * /app/frontend/dist
		encode gzip
		try_files {path} /index.html
		file_server
	}
}
