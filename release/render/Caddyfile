# Caddy: serve static assets from frontend dist; proxy page requests to backend for SEO-injected HTML
# Listen on PORT (set by Render); default 8080 for local runs
# Disable admin API so Render health checks (Host: *.onrender.com) are not rejected with 403
{
	admin off
}
:{$PORT:8080} {
	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /socket.io/* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /health {
		reverse_proxy 127.0.0.1:3000
	}
	# All static assets (JS, CSS, images, favicon, etc.) live under /assets/ after build
	handle /assets/* {
		root * /app/frontend/dist
		encode gzip
		file_server
	}
	# All other requests: proxy to backend for SEO-injected HTML
	handle {
		reverse_proxy 127.0.0.1:3000
	}
}
