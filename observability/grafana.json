            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 20 },
                { "color": "red", "value": 50 }
              ]
            },
            "unit": "percent"
          },
          "overrides": []
        },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
        "id": 4,
