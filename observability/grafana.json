        "title": "HTTP Traffic",
        "type": "row"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [{ "color": "blue", "value": null }]
            },
            "unit": "short"
          },
          "overrides": []
        },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
        "id": 2,
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "orientation": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto"
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "expr": "sum(http_requests_total{environment=\"$environment\"})",
            "instant": true,
            "legendFormat": "Total",
            "refId": "A"
          }
        ],
        "title": "Total Requests",
        "type": "stat"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
