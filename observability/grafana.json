        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "expr": "sum(rate(http_requests_total{environment=\"$environment\"}[$__rate_interval]))",
            "legendFormat": "Rate",
            "refId": "A"
