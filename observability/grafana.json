        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "expr": "sum(http_requests_total{status=~\"307|308\",environment=\"$environment\"}) / sum(http_requests_total{environment=\"$environment\"}) * 100",
